# Copy this to .env and fill in your keys.

# Google Gemini API key (https://aistudio.google.com/app/apikey) — required for /ask and /index
GOOGLE_API_KEY=your-api-key-here

# Google Cloud API key with Cloud Translation API + Cloud Text-to-Speech API enabled
# (https://console.cloud.google.com/apis/credentials)
# If left empty, the GOOGLE_API_KEY above is used as a fallback.
GOOGLE_CLOUD_API_KEY=your-cloud-api-key-here

# YouTube Data API v3 key (https://console.cloud.google.com/apis — enable YouTube Data API v3)
# Falls back to GOOGLE_CLOUD_API_KEY if left empty.
YOUTUBE_API_KEY=your-youtube-api-key-here

