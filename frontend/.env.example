# Copy this to .env.local for local development.

# Google Analytics 4 Measurement ID (e.g. G-XXXXXXXXXX)
# Get yours at https://analytics.google.com
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Google Maps Embed API key (optional — enables higher quota & custom styling)
# Enable "Maps Embed API" at https://console.cloud.google.com/apis
# Leave empty to use the keyless embed fallback (maps.google.com)
VITE_GOOGLE_MAPS_API_KEY=
